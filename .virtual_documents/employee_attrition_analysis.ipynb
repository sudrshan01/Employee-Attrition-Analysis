import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns

df = pd.read_csv("data/employee_chart.csv")

df.head()



df.info()
df.describe()



df.isnull().sum()
df['left'].value_counts()



import os

# Create output folder if it doesn't exist
os.makedirs("output", exist_ok=True)

attrition_rate = df['left'].value_counts(normalize=True) * 100

ax = attrition_rate.plot(kind='bar')
plt.xticks([0, 1], ['Stayed', 'Left'], rotation=0)
plt.ylabel("Percentage")
plt.title("Employee Attrition Rate (%)")

for p in ax.patches:
    ax.annotate(
        f'{p.get_height():.2f}%',
        (p.get_x() + p.get_width() / 2., p.get_height()),
        ha='center', va='bottom'
    )

# Save in output folder
plt.savefig("output/employee_attrition_rate.png", dpi=300, bbox_inches='tight')
plt.show()



sns.countplot(x='left', data=df)
plt.title("Employee Attrition Count")
plt.show()



print(df.columns.tolist())
df.columns = df.columns.str.strip()
df['Departments'].dropna().unique().tolist()
df['Departments'].value_counts()
df['Departments'].unique()


plt.figure(figsize=(8,5))
ax = sns.countplot(data=df, x='Departments', hue='left')
plt.xticks(rotation=45)
plt.ylabel("Number of Employees")
plt.title("Attrition by Departments")

for p in ax.patches:
    ax.annotate(
        f'{p.get_height()}',
        (p.get_x() + p.get_width() / 2., p.get_height()),
        ha='center', va='bottom'
    )
plt.savefig("output/Attrition by Departments.png",dpi=300,bbox_inches='tight')
plt.show()



ax = sns.countplot(x='promotion_last_5years', data=df)
plt.title("Employees Promotion Status (Last 5 Years)")
plt.xticks([0, 1], ['Not Promoted', 'Promoted'])

# Add exact count labels
for p in ax.patches:
    ax.annotate(
        f'{int(p.get_height())}',
        (p.get_x() + p.get_width() / 2., p.get_height()),
        ha='center', va='bottom'
    )
plt.savefig("output/Employees Promotion Status (Last 5 Years).png", dpi=400, bbox_inches='tight')
plt.show()



sns.countplot(data=df, x='salary')
plt.title("Empoyees salary category")
plt.show()



